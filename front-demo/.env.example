# Base URL for the Icicle API. Defaults to https://api.l1beat.io when unset.
# Point this at a local server (e.g. http://localhost:8080) during development.
VITE_API_BASE_URL=https://api.l1beat.io

# Operator bearer token for gated metrics endpoints (e.g. /metrics/storage), same
# value as the API's ICICLE_METRICS_TOKEN. Optional: enables the Overview storage
# panel + coverage KPIs. Leave unset to hide them. Only use this for a locally-run
# ops console — never commit a real token or ship it in a hosted build.
# VITE_METRICS_TOKEN=
