{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "API traffic analytics for api.l1beat.io, parsed from the nginx (vhost=default) access logs in Loki. Top IPs, IP x endpoint, request rate, and 4xx/5xx offenders.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "API requests (range)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "sum(count_over_time({vhost=\"default\"} |= \"/api/v1/\" [$__range]))", "queryType": "instant", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Unique IPs",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "count(sum by (ip) (count_over_time({vhost=\"default\"} |= \"/api/v1/\" | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` [$__range])))", "queryType": "instant", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Errors (4xx / 5xx)",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "sum(count_over_time({vhost=\"default\"} |= \"/api/v1/\" | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` | status=~\"4..|5..\" [$__range]))", "queryType": "instant", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Unique endpoints",
      "type": "stat",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "count(sum by (path) (count_over_time({vhost=\"default\"} |= \"/api/v1/\" | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` [$__range])))", "queryType": "instant", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 15, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "normal" }, "thresholdsStyle": { "mode": "off" } }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Request rate by status (req/s)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "sum by (status) (rate({vhost=\"default\"} |= \"/api/v1/\" | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` [$__auto]))", "legendFormat": "{{status}}", "queryType": "range", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [{ "matcher": { "id": "byName", "options": "Requests" }, "properties": [{ "id": "custom.width", "value": 110 }, { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }] }] },
      "gridPos": { "h": 12, "w": 8, "x": 0, "y": 12 },
      "id": 6,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Requests", "desc": true }] },
      "title": "Top IPs",
      "type": "table",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "topk(20, sum by (ip) (count_over_time({vhost=\"default\"} |= \"/api/v1/\" | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` [$__range])))", "queryType": "instant", "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "Requests" } } }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [{ "matcher": { "id": "byName", "options": "Requests" }, "properties": [{ "id": "custom.width", "value": 110 }, { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }] }] },
      "gridPos": { "h": 12, "w": 8, "x": 8, "y": 12 },
      "id": 7,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Requests", "desc": true }] },
      "title": "Top endpoints",
      "type": "table",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "topk(20, sum by (path) (count_over_time({vhost=\"default\"} |= \"/api/v1/\" | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` [$__range])))", "queryType": "instant", "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "Requests" } } }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [{ "matcher": { "id": "byName", "options": "Requests" }, "properties": [{ "id": "custom.width", "value": 110 }] }] },
      "gridPos": { "h": 12, "w": 8, "x": 16, "y": 12 },
      "id": 8,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Requests", "desc": true }] },
      "title": "4xx / 5xx by IP",
      "type": "table",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "topk(20, sum by (ip, status) (count_over_time({vhost=\"default\"} |= \"/api/v1/\" | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` | status=~\"4..|5..\" [$__range])))", "queryType": "instant", "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "Requests" } } }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [{ "matcher": { "id": "byName", "options": "Requests" }, "properties": [{ "id": "custom.width", "value": 120 }, { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }] }, { "matcher": { "id": "byName", "options": "path" }, "properties": [{ "id": "custom.width", "value": 520 }] }] },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 24 },
      "id": 9,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Requests", "desc": true }] },
      "title": "Which IP hits which endpoint",
      "type": "table",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "topk(50, sum by (ip, path) (count_over_time({vhost=\"default\"} |= \"/api/v1/\" | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` [$__range])))", "queryType": "instant", "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "Requests" } } }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [{ "matcher": { "id": "byName", "options": "429s" }, "properties": [{ "id": "custom.width", "value": 120 }, { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }, { "id": "color", "value": { "mode": "continuous-OrRd" } }] }] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 38 },
      "id": 10,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "429s", "desc": true }] },
      "title": "Rate-limited IPs (429)",
      "type": "table",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "topk(25, sum by (ip) (count_over_time({vhost=\"default\"} | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` | status=\"429\" [$__range])))", "queryType": "instant", "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "429s" } } }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisPlacement": "auto", "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1, "showPoints": "never", "stacking": { "group": "A", "mode": "normal" } }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 38 },
      "id": 11,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "429s over time by IP",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "loki", "uid": "${datasource}" }, "expr": "sum by (ip) (count_over_time({vhost=\"default\"} | regexp `^(?P<ip>\\S+) \\S+ \\S+ \\[[^\\]]+\\] \"(?P<method>\\S+) (?P<path>[^? ]+)[^\"]*\" (?P<status>\\d+)` | status=\"429\" [$__auto]))", "legendFormat": "{{ip}}", "queryType": "range", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": true }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 48 },
      "id": 12,
      "options": { "legend": { "calcs": ["max"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Latency p95 by endpoint (Prometheus)",
      "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${prometheus}" }, "editorMode": "code", "expr": "histogram_quantile(0.95, sum by (le, path) (rate(icicle_api_request_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{path}}", "range": true, "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus}" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true }, "unit": "s" }, "overrides": [{ "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "custom.width", "value": 140 }, { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }] }] },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 48 },
      "id": 13,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "p95", "desc": true }] },
      "title": "Slowest endpoints (p95)",
      "type": "table",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${prometheus}" }, "editorMode": "code", "expr": "topk(15, histogram_quantile(0.95, sum by (le, path) (rate(icicle_api_request_duration_seconds_bucket[$__range]))))", "format": "table", "instant": true, "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "Value": "p95" } } }
      ]
    }
  ],
